{
    "name": "cppmake",
    "displayName": "cppmake",
    "description": "cppmake",
    "icon": "share/package.png",
    "publisher": "shyeyian",
    "version": "1.1.58",
    "engines": {
        "vscode": "^1.100.0"
    },
    "categories": [
        "Language Packs"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/shyeyian/vscode-cppmake"
    },
    "main": "main/main.js",
    "activationEvents": [
        "onStartupFinished"
    ],
    "contributes": {
        "commands": [
            {
                "command": "startTask",
                "title": "%Start Task%",
                "icon": "$(run)"
            },
            {
                "command": "selectTask",
                "title": "%Select Task%",
                "icon": "$(chevron-down)"
            },
            {
                "command": "openTasksJson",
                "title": "%Open 'tasks.json'%",
                "icon": "$(gear)"
            }
        ],
        "configuration": {
            "title": "cppmake",
            "properties": {
                "cppmake.sarifDirectory": {
                    "type": "string",
                    "markdownDescription": "Path to a specific directory where contains several `.sarif` files",
                    "default": "."
                }
            }
        },
        "keybindings": {
            "key": "ctrl+shift+b",
            "command": "build.focus"
        },
        "menus": {
            "view/title": [
                {
                    "command": "startTask",
                    "when": "view == sarif",
                    "group": "navigation"
                },
                {
                    "command": "selectTask",
                    "when": "view == sarif",
                    "group": "navigation"
                },
                {
                    "command": "openTasksJson",
                    "when": "view == sarif",
                    "group": "navigation"
                }
            ]
        },
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "build",
                    "title": "%Build%",
                    "icon": "$(issues)"
                },
                {
                    "id": "run",
                    "title": "%Run%",
                    "icon": "$(run-all)"
                }
            ]
        },
        "views": {
            "build": [
                {
                    "id": "sarif",
                    "name": "%Sarif%",
                    "icon": "$(issues)"
                }
            ]
        }
    }
}
