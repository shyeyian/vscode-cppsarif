{
    "name": "cppmake",
    "displayName": "cppmake",
    "description": "cppmake",
    "icon": "share/package.png",
    "publisher": "shyeyian",
    "version": "1.1.55",
    "engines": {
        "vscode": "^1.100.0"
    },
    "categories": [
        "Language Packs"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/shyeyian/vscode-cppmake"
    },
    "main": "main/main.js",
    "activationEvents": [
        "onStartupFinished"
    ],
    "contributes": {
        "configuration": {
            "title": "cppmake",
            "properties": {
                "cppmake.sarifDirectory": {
                    "type": "string",
                    "markdownDescription": "Path to a specific directory where contains several `.sarif` files",
                    "default": "."
                }
            }
        },
        "keybindings": {
            "key": "ctrl+shift+m",
            "command": "make.focus"
        },
        "menus": {
            "view/item/context": []
        },
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "make",
                    "title": "%Make%",
                    "icon": "$(issues)"
                },
                {
                    "id": "run",
                    "title": "%Run%",
                    "icon": "$(run-all)"
                }
            ]
        },
        "views": {
            "make": [
                {
                    "id": "sarif",
                    "name": "%Sarif%",
                    "icon": "$(issues)"
                }
            ]
        }
    }
}
